{
  "manifest_version": 3,
  "name": "Dominator",
  "version": "1.0.0",
  "description": "分析知乎用户是否存在异常推广或操纵风险",
  "permissions": ["activeTab", "cookies", "tabs", "storage"],
  "host_permissions": [
    "https://www.zhihu.com/*",
    "https://api.zhihu.com/*",
    "https://dominator.rethinkos.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://www.zhihu.com/people/*", "https://www.zhihu.com/question/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["icons/dominator-loading.png"],
      "matches": ["https://www.zhihu.com/*"]
    }
  ],
  "action": {
    "default_title": "Dominator",
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
